# EditorConfig — https://editorconfig.org

root = true

# Все файлы
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# — Unity-стиль
[*.cs]
indent_size = 4
dotnet_sort_system_directives_first = true
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_indent_case_contents = true
csharp_space_after_cast = false
csharp_prefer_braces = true

# ── Линтер: StyleCop (SA) ──────────────────────────────────────────────────
dotnet_diagnostic.SA1633.severity = none   # Нет file header
dotnet_diagnostic.SA1101.severity = none   # Не требуем this. prefix
dotnet_diagnostic.SA1200.severity = none   # using вне namespace — ок
dotnet_diagnostic.SA1309.severity = none   # _underscore поля разрешены
dotnet_diagnostic.SA1512.severity = none   # Одиночный комментарий разрешён
dotnet_diagnostic.SA1516.severity = none   # Пустые строки между элементами — не обязательны
dotnet_diagnostic.SA1600.severity = none   # XML-доки не обязательны
dotnet_diagnostic.SA1601.severity = none   # XML-доки на partial — не обязательны
dotnet_diagnostic.SA1602.severity = none   # XML-доки на enum — не обязательны
dotnet_diagnostic.SA1604.severity = none
dotnet_diagnostic.SA1611.severity = none
dotnet_diagnostic.SA1615.severity = none
dotnet_diagnostic.SA1618.severity = none
dotnet_diagnostic.SA1623.severity = none
dotnet_diagnostic.SA1642.severity = none
dotnet_diagnostic.SA1643.severity = none

# ── Линтер: NetAnalyzers (CA) ─────────────────────────────────────────────
dotnet_diagnostic.CA1062.severity = none   # Unity объекты — null уже гарантирует движок
dotnet_diagnostic.CA1303.severity = none   # Не локализуем строки
dotnet_diagnostic.CA1304.severity = none
dotnet_diagnostic.CA1305.severity = none
dotnet_diagnostic.CA1307.severity = none
dotnet_diagnostic.CA1310.severity = none
dotnet_diagnostic.CA2007.severity = none   # ConfigureAwait — UniTask не требует
dotnet_diagnostic.CA1031.severity = warning  # Не глотать все исключения
dotnet_diagnostic.CA1051.severity = warning  # Не публичные поля
dotnet_diagnostic.CA1822.severity = warning  # Метод может быть static

# ── Линтер: Roslynator (RCS) ─────────────────────────────────────────────
dotnet_diagnostic.RCS1036.severity = warning  # Лишние пустые строки
dotnet_diagnostic.RCS1037.severity = warning  # Trailing whitespace в комментарии
dotnet_diagnostic.RCS1118.severity = warning  # Неиспользуемый параметр
dotnet_diagnostic.RCS1138.severity = none     # XML-доки — не обязательны
dotnet_diagnostic.RCS1139.severity = none

# ── Линтер: Unity Analyzers (UNT) ────────────────────────────────────────
# Type Safety
dotnet_diagnostic.UNT0003.severity = warning  # Не-generic GetComponent
dotnet_diagnostic.UNT0006.severity = warning  # Некорректная сигнатура Message
dotnet_diagnostic.UNT0010.severity = warning  # new Component() вместо AddComponent
dotnet_diagnostic.UNT0011.severity = warning  # new ScriptableObject() вместо CreateInstance
dotnet_diagnostic.UNT0013.severity = warning  # Невалидный SerializeField
dotnet_diagnostic.UNT0014.severity = warning  # GetComponent с не-Component типом
dotnet_diagnostic.UNT0016.severity = warning  # nameof() вместо строки для методов
dotnet_diagnostic.UNT0039.severity = warning  # Требовать RequireComponent

# Correctness
dotnet_diagnostic.UNT0004.severity = warning  # Time.fixedDeltaTime в Update
dotnet_diagnostic.UNT0007.severity = warning  # Null-coalescing на Unity-объектах (ломает fake-null)
dotnet_diagnostic.UNT0008.severity = warning  # Null-propagation на Unity-объектах
dotnet_diagnostic.UNT0012.severity = warning  # Неиспользуемый return coroutine
dotnet_diagnostic.UNT0020.severity = warning  # MenuItem на не-static методе
dotnet_diagnostic.UNT0023.severity = warning  # ??= на Unity-объектах
dotnet_diagnostic.UNT0025.severity = warning  # Input.GetKey с KeyCode вместо string
dotnet_diagnostic.UNT0029.severity = warning  # Pattern matching с null на Unity-объектах
dotnet_diagnostic.UNT0030.severity = warning  # Destroy на Transform вместо GameObject
dotnet_diagnostic.UNT0031.severity = warning  # Asset-операции в LoadAttribute
dotnet_diagnostic.UNT0033.severity = warning  # Неправильный регистр message
dotnet_diagnostic.UNT0040.severity = warning  # isStatic — editor-only

# Performance
dotnet_diagnostic.UNT0001.severity = warning  # Пустой Update()
dotnet_diagnostic.UNT0002.severity = warning  # tag == "..." → CompareTag()
dotnet_diagnostic.UNT0017.severity = warning  # SetPixels медленный
dotnet_diagnostic.UNT0018.severity = warning  # Рефлексия в горячих методах
dotnet_diagnostic.UNT0019.severity = warning  # gameObject.gameObject
dotnet_diagnostic.UNT0022.severity = warning  # position + rotation раздельно → SetPositionAndRotation
dotnet_diagnostic.UNT0024.severity = warning  # Векторные операции → скалярные
dotnet_diagnostic.UNT0026.severity = warning  # GetComponent всегда аллоцирует
dotnet_diagnostic.UNT0028.severity = warning  # Не-аллоцирующие физикс-API
dotnet_diagnostic.UNT0032.severity = warning  # localPosition + localRotation раздельно
dotnet_diagnostic.UNT0036.severity = warning  # get position + get rotation раздельно
dotnet_diagnostic.UNT0037.severity = warning  # get localPosition + get localRotation раздельно
dotnet_diagnostic.UNT0038.severity = warning  # Кешировать new WaitForSeconds()
dotnet_diagnostic.UNT0041.severity = warning  # Animator.StringToHash вместо строк

# Readability
dotnet_diagnostic.UNT0034.severity = suggestion  # Vector3 → Vector2
dotnet_diagnostic.UNT0035.severity = suggestion  # Vector2 → Vector3

# Message protection
dotnet_diagnostic.UNT0021.severity = warning  # Unity-сообщения должны быть protected
# Retired / intentionally disabled
dotnet_diagnostic.UNT0005.severity = none     # [retired] Time.deltaTime в FixedUpdate
dotnet_diagnostic.UNT0042.severity = none     # Mesh array access in loop — слишком шумно
dotnet_diagnostic.UNT0043.severity = warning  # Опечатка в conditional compilation symbol

# Шейдеры
[*.{shader,hlsl,cginc,compute}]
indent_size = 4

# Unity YAML (сцены, префабы, ассеты)
[*.{unity,prefab,asset,mat,anim,controller,mask}]
indent_size = 2
trim_trailing_whitespace = false

# UI Toolkit
[*.{uxml,uss}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# JSON
[*.json]
indent_size = 2
